# Vercel Deployment Environment Variables

# Database - Create a Neon PostgreSQL project and get the connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.neon.tech/reemote?sslmode=require

# Authentication - Generate strong secrets (min 32 chars)
JWT_SECRET=your-jwt-secret-32-characters-minimum-here
ENCRYPTION_KEY=your-encryption-key-32-characters-minimum

# Libvirt Configuration (optional for VM management)
LIBVIRT_URI=qemu:///system

# Logging
LOG_LEVEL=info

# Frontend Environment (automatically set by Vercel)
VITE_API_URL=https://your-project.vercel.app/api/v1

# Rate Limiting (optional)
SECURITY_USER_RATELIMIT=100
SECURITY_IP_RATELIMIT=1000
SECURITY_RATELIMIT_WINDOW=1m

# Certificate Management (optional)
CERT_EXPIRY_WARNING_DAYS=30

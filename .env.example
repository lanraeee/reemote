# Server Configuration
SERVER_PORT=8443
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=10s
SERVER_MAX_CONNECTIONS=10000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=reemote
DB_PASSWORD=changeme
DB_NAME=reemote
DB_SSL_MODE=require
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Authentication Configuration
JWT_SECRET=your-secret-key-min-32-chars-long-change-this
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h
TOTP_WINDOW_SIZE=1
PASSWORD_MIN_LENGTH=12
SESSION_TIMEOUT=24h

# Libvirt Configuration
LIBVIRT_URI=qemu:///system
LIBVIRT_TIMEOUT=30s
LIBVIRT_EVENT_TIMEOUT=5m
LIBVIRT_CIRCUIT_LIMIT=5
LIBVIRT_CIRCUIT_RESET=30s
LIBVIRT_MAX_POOLING=10

# Security Configuration
ALLOWED_CORS_ORIGINS=http://localhost:3000
ENCRYPTION_KEY=your-encryption-key-min-32-chars-long-change-this
BCRYPT_COST=12
TLS_MIN_VERSION=1.3
REQUIRE_TLS=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Environment
ENV=development

# Reemote Connect — Docker deployment environment
# Copy to .env and fill in values before running docker compose up

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=reemote
DB_PASSWORD=changeme_use_strong_password
DB_NAME=reemote

# ── Auth secrets (min 32 chars each) ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ENCRYPTION_KEY=change_this_to_a_random_64_char_string_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# ── Email (optional — uses Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Reemote <noreply@yourdomain.com>

# ── Ports ─────────────────────────────────────────────────────────────────────
HTTP_PORT=80
# HTTP_PORT=8080   # use a non-privileged port if not running as root

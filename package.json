{
  "name": "reemote",
  "version": "1.0.0",
  "description": "Remote desktop VM platform — Vercel & self-hosted Docker",
  "main": "dist-server/server/index.js",
  "scripts": {
    "dev:api": "tsc --watch -p tsconfig.api.json",
    "build": "cd frontend && npm install && npm run build",
    "server:build": "tsc -p tsconfig.server.json",
    "server:start": "node dist-server/server/index.js",
    "server:dev": "ts-node-dev --respawn --transpile-only -p tsconfig.server.json server/index.ts",
    "start": "npm run server:start",
    "test": "jest"
  },
  "dependencies": {
    "@vercel/node": "^2.15.1",
    "express": "^4.18.3",
    "dockerode": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/dockerode": "^3.3.23",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.2",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
